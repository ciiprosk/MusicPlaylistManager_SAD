<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox alignment="TOP_CENTER"
      spacing="10.0"
      styleClass="playlist-card"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.diem.unisa.musicmanager.controller.PlaylistCardController">

    <padding>
        <Insets bottom="0.0" left="0.0" right="0.0" top="0.0"/>
    </padding>

    <!-- Cover area -->
    <StackPane prefHeight="140.0" prefWidth="140.0">
        <!-- Background placeholder con rettangolo arrotondato -->
        <Rectangle arcHeight="8.0"
                   arcWidth="8.0"
                   fill="#333333"
                   height="140.0"
                   width="140.0"/>

        <!-- Icona playlist (placeholder) -->
        <Label fx:id="lblPlaylistIcon"
               text="🎵"
               styleClass="playlist-icon"/>
    </StackPane>

    <!-- Nome playlist -->
    <Label fx:id="labelName"
           text="Nome Playlist"
           styleClass="playlist-nome"
           wrapText="true"
           textAlignment="CENTER"/>

    <!-- Numero tracce -->
    <Label fx:id="labelTracks"
           text="0 tracce"
           styleClass="playlist-tracce"/>

    <!-- Bottoni azioni -->
    <HBox alignment="CENTER"
          spacing="8.0"
          styleClass="playlist-actions">
        <Button fx:id="btnPlay"
                text="▶"
                onAction="#handlePlay"
                styleClass="btn-playlist-play"/>
        <Button fx:id="btnMenu"
                text="···"
                onAction="#handleMenu"
                styleClass="btn-playlist-menu"/>
    </HBox>

</VBox>
