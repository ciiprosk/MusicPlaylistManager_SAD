<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER" maxHeight="80.0" maxWidth="Infinity" minHeight="80.0" prefHeight="80.0" spacing="15.0" styleClass="player-bar" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.diem.unisa.musicmanager.controller.PlayerController">

   <padding>
      <Insets left="20.0" right="20.0" />
   </padding>

   <!-- SEZIONE 1: controlli playback -->
   <HBox alignment="CENTER" spacing="8.0">
      <Button fx:id="buttonPlay" onAction="#handlePlayPause" styleClass="btn-player" text="▶" />

      <Button fx:id="buttonNext" onAction="#handleNext" styleClass="btn-player" text="⏭" />

      <Button fx:id="buttonSkipPlaylist" disable="true" onAction="#handleSkipPlaylist" styleClass="btn-player" text="⏭" />
   </HBox>
   <VBox alignment="CENTER" spacing="4.0" HBox.hgrow="ALWAYS">
      <HBox alignment="CENTER" spacing="6.0">
         <Label fx:id="labelTrack" styleClass="player-titolo" text="Track" />
         <Label fx:id="labelSeparator" styleClass="player-artista" text="-" />
         <Label fx:id="labelAuthor" styleClass="player-artista" text="Author" />
      </HBox>
      <HBox alignment="CENTER" spacing="8.0">
         <Label fx:id="labelTime" styleClass="player-timer" text="00:00" />
         <Slider fx:id="sliderProgress" styleClass="slider-progresso" HBox.hgrow="ALWAYS" />
         <Label fx:id="labelDuration" styleClass="player-timer" text="00:00" />
      </HBox>
   </VBox>
   
   <HBox alignment="CENTER" spacing="8.0">
      <Button fx:id="buttonMode" onAction="#handleChangeMode" styleClass="btn-player" text="🔁" />

      <Button fx:id="buttonQueue" onAction="#handleQueue" styleClass="btn-player" text="☰" />
   </HBox>

</HBox>
