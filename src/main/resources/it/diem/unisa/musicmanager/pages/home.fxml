<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" styleClass="sfondo-principale" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.diem.unisa.musicmanager.controller.HomeController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <children>
        <Label styleClass="titolo-pagina" text="Home" textFill="WHITE">
            <font>
                <Font size="32.0" />
            </font>
        </Label>

        <javafx.scene.layout.StackPane alignment="CENTER_RIGHT" maxWidth="600.0" minWidth="250.0" prefWidth="400.0">
            <TextField fx:id="searchBar" promptText="Search" styleClass="search-bar" />
            <javafx.scene.control.Button fx:id="btnClearSearch" text="✕" style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 0 10 0 0;" visible="false" />
        </javafx.scene.layout.StackPane>

        <Label styleClass="sottotitolo" text="Most Played Tracks" textFill="#cccccc" />
        <VBox fx:id="topTracksContainer" spacing="10.0">
        </VBox>

        <Label styleClass="sottotitolo" text="Playlists" textFill="#cccccc" />
        <VBox fx:id="recentPlaylistsContainer" spacing="10.0">
        </VBox>
    </children>
</VBox>