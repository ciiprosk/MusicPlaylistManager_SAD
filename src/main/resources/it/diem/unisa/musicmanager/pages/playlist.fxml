<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" styleClass="sfondo-principale" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.diem.unisa.musicmanager.controller.PlaylistController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT">
            <Label styleClass="titolo-pagina" text="Playlists" textFill="WHITE" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="buttonAddPlaylist" maxWidth="150.0" minWidth="120.0" mnemonicParsing="false" onAction="#openCreatePlaylist" styleClass="btn-primario" text="Add Playlist" />
        </HBox>

        <TextField fx:id="searchBar" maxWidth="600.0" minWidth="250.0" prefWidth="400.0" promptText="Search" styleClass="search-bar" />

        <FlowPane fx:id="playlistsGrid" hgap="20.0" vgap="20.0" VBox.vgrow="ALWAYS">
        </FlowPane>
    </children>
</VBox>
