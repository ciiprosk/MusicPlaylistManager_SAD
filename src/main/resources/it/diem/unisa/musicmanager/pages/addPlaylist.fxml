<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="sfondo-principale" stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.diem.unisa.musicmanager.controller.AddPlaylistController">

    <padding>
        <Insets bottom="25.0" left="30.0" right="30.0" top="20.0" />
    </padding>

    <children>

        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Label styleClass="menu-title" text="Create Playlist" textFill="#a0a0a0" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label minWidth="160.0" styleClass="sottotitolo" text="Name" textFill="#cccccc" />
            <TextField fx:id="fieldName" styleClass="form-field" HBox.hgrow="ALWAYS" />
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <Label fx:id="lblError" maxWidth="Infinity" textFill="#ff5555" HBox.hgrow="ALWAYS" />
            <Button fx:id="buttonCancel" onAction="#onCancel" styleClass="button-grigio" text="Cancel" textFill="WHITE" />
            <Button fx:id="buttonCreate" onAction="#onCreate" styleClass="button-verde" text="Create" textFill="WHITE" />
        </HBox>

    </children>
</VBox>
